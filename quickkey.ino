// === Forward declarations ===
void renderDisplay(int frameIndex);
void handleMessage(const String &msg);
void busSend(const String &msg);
void broadcastMessage(const String &msg);
void setupGUID();
void setupUnitName();
void determineRole();
void updateSlaveList(const String &slaveGuid, const String &slaveName);
void checkCombo(const String &name);
void enterState(AnimState s, const String &overlay);

// === Setup GUID ===
void setupGUID() {
  uint64_t chipid = ESP.getEfuseMac();
  guid = String((uint32_t)(chipid >> 32), HEX) + String((uint32_t)chipid, HEX);
}

void setupUnitName() {
  prefs.begin("quickkey", false);
  unitName = prefs.getString("name", "");
  if (unitName.length() == 0) {
    unitName = guid.substring(guid.length() - 4);
    prefs.putString("name", unitName);
  }
  prefs.end();
}

// === Determine master/slave role ===
void determineRole() {
  if (digitalRead(PIN_FLAG) == HIGH) {
    isMaster = false;
    pinMode(PIN_FLAG, INPUT);
  } else {
    isMaster = true;
    pinMode(PIN_FLAG, OUTPUT);
    digitalWrite(PIN_FLAG, HIGH);
  }
}

// === Send message over bus ===
void busSend(const String &msg) {
  Serial1.println(msg);
}

// === Broadcast message over Wi-Fi and bus ===
void broadcastMessage(const String &msg) {
  // Add source GUID to message if not already present
  String fullMsg = msg;
  if (!msg.endsWith(guid)) {
    fullMsg = msg + "_" + guid;
  }
  
  if (wifiActive) {
    udp.beginPacket(broadcastIP, udpPort);
    udp.print(fullMsg);
    udp.endPacket();
  }
  busSend(fullMsg);
}

// === State transition helper ===
void enterState(AnimState s, const String &overlay) {
  animState = s;
  stateStartTime = millis();
  currentFrame = 0;
  animationReverse = false;
  overlayText = overlay;
}

// === Slave list update ===
void updateSlaveList(const String &slaveGuid, const String &slaveName) {
  unsigned long now = millis();
  for (int i = 0; i < slaveCount; i++) {
    if (slaves[i].guid == slaveGuid) {
      slaves[i].lastSeen = now;
      slaves[i].name = slaveName;
      return;
    }
  }
  if (slaveCount < MAX_SLAVES) {
    slaves[slaveCount] = { slaveGuid, slaveName, now };
    slaveCount++;
    Serial.println("Slave joined: " + slaveName);
  }
}

// === Combo detection ===
void checkCombo(const String &name) {
  unsigned long now = millis();
  int kept = 0;
  for (int i = 0; i < recentTriggerCount; i++) {
    if (now - recentTriggers[i].time < COMBO_WINDOW_MS)
      recentTriggers[kept++] = recentTriggers[i];
  }
  recentTriggerCount = kept;

  bool found = false;
  for (int i = 0; i < recentTriggerCount; i++) {
    if (recentTriggers[i].name == name) { found = true; break; }
  }
  if (!found && recentTriggerCount < MAX_COMBO_TRACK) {
    recentTriggers[recentTriggerCount] = { name, now };
    recentTriggerCount++;
  }

  if (recentTriggerCount >= 2) {
    recentTriggerCount = 0;
    broadcastMessage("COMBO");
    enterState(COMBO, "COMBO!");
  }
}

// === Handle received command ===
void handleMessage(const String &msg) {
  if (msg.startsWith("TRIGGER")) {
    int first  = msg.indexOf('_');
    int second = msg.indexOf('_', first + 1);
    String senderName = (first >= 0 && second > first) ? msg.substring(first + 1, second) : "?";
    String senderGuid = (second >= 0) ? msg.substring(second + 1) : "";

    enterState(TRIGGERED, senderName);

    if (isMaster && senderGuid != guid) {
      broadcastMessage(msg);
      checkCombo(senderName);
    } else if (isMaster) {
      checkCombo(senderName);
    }

  } else if (msg.startsWith("COMBO")) {
    enterState(COMBO, "COMBO!");

  } else if (msg.startsWith("SLAVE_CONNECTED")) {
    int first  = msg.indexOf('_', 16);
    int second = (first >= 0) ? msg.indexOf('_', first + 1) : -1;
    String slaveName = (first >= 0 && second > first) ? msg.substring(first + 1, second) : "?";
    String slaveGuid = (second >= 0) ? msg.substring(second + 1) : msg.substring(first + 1);
    if (isMaster) updateSlaveList(slaveGuid, slaveName);
  }
}

// === Setup ===
void setup() {
  Serial.begin(115200);
  delay(200);

  pinMode(PIN_BUTTON, INPUT_PULLUP);
  pinMode(PIN_FLAG, INPUT_PULLDOWN);

  Wire.begin(PIN_SDA, PIN_SCL);

  if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) {
    Serial.println("❌ OLED init failed!");
    for (;;);
  }
  display.clearDisplay();
  display.display();

  setupGUID();
  setupUnitName();
  delay(200);
  determineRole();

  // Dynamically swap RX/TX for slaves
  int serialRxPin = PIN_RX;
  int serialTxPin = PIN_TX;
  if (!isMaster) {
    serialRxPin = PIN_TX;
    serialTxPin = PIN_RX;
  }

  Serial1.begin(BAUD, SERIAL_8N1, serialRxPin, serialTxPin);

  Serial.println(isMaster ? "🔸 MASTER started" : "🔹 SLAVE started");
  Serial.println("GUID: " + guid);
  Serial.println("Name: " + unitName);

  delay(500);

  // Slaves announce themselves immediately after setup
  if (!isMaster) {
    String packet = "SLAVE_CONNECTED_" + unitName + "_" + guid;
    busSend(packet);
    Serial.println("📡 Announcing to master");
  }

  delay(500);

  // Master connects to Wi-Fi
  if (isMaster) {
    WiFi.mode(WIFI_STA);
    WiFi.begin(ssid, password);
    Serial.print("Connecting to Wi-Fi");
    unsigned long startAttempt = millis();
    while (WiFi.status() != WL_CONNECTED && millis() - startAttempt < 10000) {
      delay(300);
      Serial.print(".");
    }

    if (WiFi.status() == WL_CONNECTED) {
      wifiActive = true;
      IPAddress local = WiFi.localIP();
      IPAddress subnet = WiFi.subnetMask();
      for (int i = 0; i < 4; i++) broadcastIP[i] = local[i] | (~subnet[i]);
      Serial.println("\n✅ Wi-Fi connected!");
      Serial.print("Local IP: "); Serial.println(local);
      Serial.print("Broadcast IP: "); Serial.println(broadcastIP);
      udp.begin(udpPort);
    } else {
      wifiActive = false;
      WiFi.disconnect(true);
      WiFi.mode(WIFI_OFF);
      Serial.println("\n⚠️ Wi-Fi failed, using bus only");
    }
  }

  // Display role on screen
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  const char* roleLabel = isMaster ? "MASTER" : "SLAVE";
  display.setCursor((SCREEN_WIDTH - strlen(roleLabel) * 6) / 2, 18);
  display.print(roleLabel);
  display.setTextSize(2);
  display.setCursor((SCREEN_WIDTH - unitName.length() * 12) / 2, 30);
  display.print(unitName);
  display.setTextSize(1);
  display.display();
  delay(1500);
  display.clearDisplay();
  renderDisplay(0);
}

// === Main loop ===
void loop() {
  unsigned long now = millis();

  // === Handle button input ===
  bool reading = digitalRead(PIN_BUTTON);
  if (reading != lastButtonReading) lastDebounceTime = now;

  if ((now - lastDebounceTime) > debounceDelay) {
    if (reading != buttonState) {
      buttonState = reading;
      if (buttonState == LOW) {
        buttonPressedAt = now;
        longPressFired = false;
      } else {
        if (!longPressFired) {
          String packet = "TRIGGER_" + unitName + "_" + guid;
          if (isMaster) broadcastMessage(packet);
          else busSend(packet);
          handleMessage(packet);
          Serial.println(packet);
        }
      }
    }
    if (buttonState == LOW && !longPressFired && now - buttonPressedAt >= LONG_PRESS_MS) {
      longPressFired = true;
      handleMessage("TRIGGER_" + unitName + "_" + guid);
      Serial.println("Long press: self-only");
    }
  }
  lastButtonReading = reading;

  // === Receive from Wi-Fi ===
  if (wifiActive) {
    int packetSize = udp.parsePacket();
    if (packetSize) {
      char incoming[256];
      int len = udp.read(incoming, 255);
      if (len > 0) incoming[len] = 0;
      handleMessage(String(incoming));
    }
  }

  // === USB serial commands ===
  if (Serial.available()) {
    String cmd = Serial.readStringUntil('\n');
    cmd.trim();
    if (cmd.startsWith("name=")) {
      String newName = cmd.substring(5);
      newName.trim();
      if (newName.length() > 0 && newName.length() <= 12) {
        unitName = newName;
        prefs.begin("quickkey", false);
        prefs.putString("name", unitName);
        prefs.end();
        Serial.println("Name set: " + unitName);
      }
    }
  }

  // === Receive from Serial bus ===
  while (Serial1.available()) {
    String msg = Serial1.readStringUntil('\n');
    msg.trim();
    if (msg.length() > 0) {
      handleMessage(msg);
    }
  }

  // === Periodic slave announce ===
  if (!isMaster && now - lastSlaveAnnounce > slaveAnnounceInterval) {
    lastSlaveAnnounce = now;
    busSend("SLAVE_CONNECTED_" + unitName + "_" + guid);
  }

  // === Prune stale slaves ===
  if (isMaster) {
    for (int i = 0; i < slaveCount; i++) {
      if (now - slaves[i].lastSeen > SLAVE_TIMEOUT) {
        Serial.println("Slave lost: " + slaves[i].name);
        slaves[i] = slaves[--slaveCount];
        i--;
      }
    }
  }

  // === Master loss detection ===
  if (!isMaster && digitalRead(PIN_FLAG) == LOW) {
    unsigned long lostTime = millis();
    while (digitalRead(PIN_FLAG) == LOW && millis() - lostTime < 2000);
    if (digitalRead(PIN_FLAG) == LOW) {
      uint32_t backoff = strtoul(guid.substring(0, 8).c_str(), nullptr, 16) % 500;
      delay(backoff);
      if (digitalRead(PIN_FLAG) == LOW) {
        Serial.println("⚡ Master lost, promoting self");
        pinMode(PIN_FLAG, OUTPUT);
        digitalWrite(PIN_FLAG, HIGH);
        isMaster = true;
      }
    }
  }

  // === Animation state machine ===
  int frameInterval = (animState == COMBO) ? COMBO_FRAME_DELAY :
                      (animState == TRIGGERED) ? TRIGGERED_FRAME_DELAY : IDLE_FRAME_DELAY;

  if (now - lastFrameTime >= (unsigned long)frameInterval) {
    lastFrameTime = now;
    renderDisplay(currentFrame);

    if (animState == IDLE) {
      if (!animationReverse) {
        currentFrame++;
        if (currentFrame >= frameCount - 1) { currentFrame = frameCount - 1; animationReverse = true; }
      } else {
        currentFrame--;
        if (currentFrame <= 0) { currentFrame = 0; animationReverse = false; }
      }
    } else {
      currentFrame = (currentFrame + 1) % frameCount;
      unsigned long elapsed = now - stateStartTime;
      unsigned long duration = (animState == COMBO) ? COMBO_DURATION : TRIGGERED_DURATION;
      if (elapsed >= duration) enterState(IDLE, "");
    }
  }
}

// === Render frame with overlay ===
void renderDisplay(int frameIndex) {
  bool hasOverlay = overlayText.length() > 0;
  int yOffset = hasOverlay ? 16 : 9;

  display.clearDisplay();
  display.drawBitmap(
    (SCREEN_WIDTH - 46) / 2,
    (SCREEN_HEIGHT - 46) / 2 + yOffset,
    frames[frameIndex],
    46, 46, SSD1306_WHITE
  );

  if (hasOverlay) {
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    display.setCursor((SCREEN_WIDTH - overlayText.length() * 6) / 2, 1);
    display.print(overlayText);
  }

  if (isMaster && slaveCount > 0) {
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    display.setCursor(0, 0);
    display.print(slaveCount);
  }

  display.display();
}